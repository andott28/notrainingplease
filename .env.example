# NVIDIA API Configuration
NVIDIA_API_KEY=your_real_nvidia_api_key
NVIDIA_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# Proxy Server Configuration
PROXY_HOST=127.0.0.1
PROXY_PORT=8787
UPSTREAM_TIMEOUT_S=120

# Protection and Masking Strategy
# PROTECTION_MODE: off, balanced (default), strict
PROTECTION_MODE=balanced

# Strict mode backend handling
# STRICT_BACKEND: reject (default) or local
# Set STRICT_LOCAL_URL to forward strictly-sensitive requests to a local model
STRICT_BACKEND=reject
STRICT_LOCAL_URL=
STRICT_LOCAL_TIMEOUT_S=30

# Masking strategy: token_substitution (default) or opaque
MASKING_STRATEGY=token_substitution

# Tokenizer model for token_substitution strategy
TOKEN_CIPHER_MODEL_ID=Qwen/Qwen2.5-Coder-1.5B-Instruct

# Session vault: maintains masking consistency across requests
SESSION_VAULT_ENABLED=true
SESSION_VAULT_TTL_S=86400
SESSION_VAULT_MAX_SESSIONS=1000

# Local API key (generated by GUI, optional for CLI usage)
# LOCAL_API_KEY=sk-local-xxxx
